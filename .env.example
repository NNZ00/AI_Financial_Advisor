# LLM (Google Gemini) 
GOOGLE_API_KEY=your-google-ai-studio-key

# Model IDs as provider:model. Change the prefix to switch providers later.
WORKHORSE_MODEL=google_genai:gemini-2.5-flash
STRATEGIST_MODEL=google_genai:gemini-2.5-pro

# Web search 
TAVILY_API_KEY=your-tavily-key

# LangSmith tracing (EU endpoint) 
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=trading-agent
